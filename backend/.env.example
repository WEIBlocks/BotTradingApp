# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis
REDIS_URL=redis://default:password@host:port

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Google Play IAP (Android) ────────────────────────────────────────────────
# How to get:
# 1. Google Play Console → Setup → API access → Link to Google Cloud project
# 2. Google Cloud Console → IAM → Service Accounts → Create service account
# 3. Grant role: "Service Account User" + go back to Play Console and grant access
# 4. Create key (JSON) → download the file
# 5. Paste the entire JSON content as a single-line string (replace newlines with \n)
# In dev: leave empty — all purchases auto-accepted without verification
GOOGLE_PLAY_SERVICE_KEY=
GOOGLE_PLAY_PACKAGE_NAME=com.botttradeapp

# ── Apple App Store IAP (iOS) ─────────────────────────────────────────────────
# How to get App-Specific Shared Secret:
# 1. App Store Connect → Apps → {Your App} → Monetization → Subscriptions
# 2. Click "App-Specific Shared Secret" → Generate (if first time) → Copy
# In dev: leave empty — all purchases auto-accepted without verification
APPLE_SHARED_SECRET=
# iOS app bundle identifier (must match Apple Developer portal)
APPLE_BUNDLE_ID=com.botttradeapp

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Exchange Encryption (64 hex chars = 32 bytes)
EXCHANGE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Alpaca (Stock Trading - get free paper keys at alpaca.markets)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Coinbase OAuth (for exchange connection)
COINBASE_CLIENT_ID=
COINBASE_CLIENT_SECRET=
COINBASE_REDIRECT_URI=bottrade://exchange/callback

# File Upload (S3 or MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=bottrade-uploads
S3_REGION=us-east-1

# AI LLM Providers (set at least one API key)
# Provider: 'auto' picks the first configured key | 'anthropic' | 'gemini' | 'openai'
AI_PROVIDER=auto
AI_MODEL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# AI Mode: 'development' uses free resources | 'production' uses paid APIs
AI_MODE=development

# YouTube Data API v3 (for video metadata + transcripts)
YOUTUBE_API_KEY=

# ─── Firebase Cloud Messaging (Push Notifications) ──────────────────────────
# How to get credentials:
# 1. Go to https://console.firebase.google.com/
# 2. Create a project (or select existing)
# 3. Go to Project Settings → Service Accounts
# 4. Click "Generate new private key" → downloads a JSON file
# 5. Copy these values from the JSON file:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# For FIREBASE_PRIVATE_KEY: Copy the "private_key" value from the JSON file
# Replace actual newlines with \n (keep the quotes)
FIREBASE_PRIVATE_KEY=

# CORS Origins (comma-separated, production only)
CORS_ORIGINS=https://bottrade.app
