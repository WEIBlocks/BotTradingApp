# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis
REDIS_URL=redis://default:password@host:port

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google Play IAP (In-App Purchases)
# Service account key for server-side receipt verification
# Create in Google Cloud Console > Service Accounts > Keys > JSON
# In production: set to the access token or base64-encoded JSON key
# In dev: leave empty to accept all purchases without verification
GOOGLE_PLAY_SERVICE_KEY=
GOOGLE_PLAY_PACKAGE_NAME=com.botttradeapp

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Exchange Encryption (64 hex chars = 32 bytes)
EXCHANGE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Coinbase OAuth (for exchange connection)
COINBASE_CLIENT_ID=
COINBASE_CLIENT_SECRET=
COINBASE_REDIRECT_URI=bottrade://exchange/callback

# File Upload (S3 or MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=bottrade-uploads
S3_REGION=us-east-1

# AI LLM Providers (set at least one API key)
# Provider: 'auto' picks the first configured key | 'anthropic' | 'gemini' | 'openai'
AI_PROVIDER=auto
AI_MODEL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# AI Mode: 'development' uses free resources | 'production' uses paid APIs
AI_MODE=development

# YouTube Data API v3 (for video metadata + transcripts)
YOUTUBE_API_KEY=

# CORS Origins (comma-separated, production only)
CORS_ORIGINS=https://bottrade.app
